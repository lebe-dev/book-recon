# Telegram bot token from @BotFather
TELEGRAM_TOKEN=123456:ABC-DEF

# Users allowed to access the bot (comma-separated, no @, case-insensitive).
# If empty — access is managed via approve/deny flow.
ALLOWED_USERS=johndoe,janedoe

# Bot administrators (can approve/deny users, send broadcasts)
ADMIN_USERS=johndoe

# Path to SQLite database
DB_PATH=book-recon.db

# Log level: debug, info, warn, error
LOG_LEVEL=info

# User-Agent for HTTP requests to providers
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/134.0.0.0 Safari/537.36

# --- Flibusta ---
FLIBUSTA_BASE_URL=https://flibusta.is
FLIBUSTA_ENABLED=true
# Engine: "default" (HTML scraper) or "v2" (OPDS)
FLIBUSTA_ENGINE=default

# --- RoyalLib ---
ROYALLIB_BASE_URL=https://royallib.com
ROYALLIB_ENABLED=false

# --- RuTracker via Jackett ---
# RuTracker requires a running Jackett instance (see docker-compose.yml).
# Initial setup:
#   1. Generate a random string, put it in jackett/ServerConfig.json (field "APIKey")
#      and here in JACKETT_API_KEY — they must match.
#   2. Start Jackett: docker compose up -d jackett
#   3. Open Web UI via SSH tunnel:
#        ssh -L 9117:localhost:9117 your-server
#        then http://localhost:9117
#   4. Add indexer "RuTracker.RU", enter your RuTracker login/password
RUTRACKER_ENABLED=false

# Jackett instance URL. No need to change when using docker-compose.
JACKETT_URL=http://localhost:9117
# docker
# JACKETT_URL=http://jackett:9117

# Jackett API key. Must match "APIKey" in jackett/ServerConfig.json.
# Required when RUTRACKER_ENABLED=true.
JACKETT_API_KEY=

# Indexer name in Jackett. Default "rutracker" — matches what is created when adding RuTracker.RU.
JACKETT_INDEXER=rutracker

# Comma-separated Torznab category IDs to filter search results.
# Empty = no filtering (all categories). Example: 7000 = all books.
# Find category IDs in Jackett UI → indexer → Categories.
JACKETT_CATEGORIES=7000

# Torrent download timeout (Go duration: 5m, 10m, 1h)
RUTRACKER_DOWNLOAD_TIMEOUT=5m

# Maximum number of books from a single torrent to send to the user
RUTRACKER_MAX_BOOKS=5

# Maximum torrent size in bytes (52428800 = 50 MB). Larger torrents will be rejected.
RUTRACKER_MAX_TORRENT_SIZE=52428800

# Directory for temporary torrent files. Cleared on bot startup.
RUTRACKER_DOWNLOAD_DIR=/tmp/book-recon-torrents
